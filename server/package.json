{
  "name": "readshift-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate --schema ../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ../prisma/schema.prisma",
    "db:seed": "tsx ../prisma/seed.ts",
    "db:studio": "prisma studio --schema ../prisma/schema.prisma",
    "db:migrate-fonts": "tsx src/scripts/migrate_font_sizes.ts",
    "db:disable-features": "tsx src/scripts/disable_non_admin_features.ts",
    "benchmark:perf": "tsx src/scripts/benchmarkDashboard.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.14.0",
    "bullmq": "^5.7.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.19.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.3.0",
    "jose": "^5.2.0",
    "node-fetch": "^2.7.0",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "undici": "^8.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prisma": "^5.14.0",
    "supertest": "^7.2.2",
    "tsx": "^4.9.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
