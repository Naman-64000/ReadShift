# ─────────────────────────────────────────────────────────────
# ReadShift — Environment Variables Reference
# Copy this file to .env and fill in all values before running.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Node Environment ──────────────────────────────────────────
NODE_ENV=development          # development | staging | production

# ── Database (PostgreSQL) ─────────────────────────────────────
# Full Prisma-format connection URL
DATABASE_URL="postgresql://readshift:readshift_dev_password@localhost:5432/readshift_dev?schema=public"

POSTGRES_USER=readshift
POSTGRES_PASSWORD=readshift_dev_password
POSTGRES_DB=readshift_dev

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Server ────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173   # Vite dev server origin

# ── Supabase Auth Provider ────────────────────────────────────
# Backend: used to verify JWT issuer / JWKS
SUPABASE_URL=https://your-project-ref.supabase.co

# Frontend (Vite public env vars — must be prefixed with VITE_)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional dev-mode bypass token support (should remain false in production)
ALLOW_DEV_TOKEN=false

# ── AI Generation (Google Gemini) ─────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── API URL (consumed by the frontend) ───────────────────────
VITE_API_BASE_URL=http://localhost:3001/api

# ── BullMQ / Job Queue ────────────────────────────────────────
# Uses REDIS_URL above — no separate config needed unless using a separate Redis instance
# BULLMQ_REDIS_URL=redis://localhost:6379

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug               # debug | info | warn | error

# ── Passage Pool ──────────────────────────────────────────────
# Minimum passages per domain-level combo before top-up job triggers
PASSAGE_POOL_MIN_THRESHOLD=50
