// Prisma schema for ReadShift
// Docs: https://pris.ly/d/prisma-schema
// Run `npx prisma migrate dev` after any changes.

generator client {
  provider      = "prisma-client-js"
  output        = "../server/node_modules/@prisma/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Domain {
  philosophy
  psychology
  history
  arts_and_museum
  society
  culture
  biology
  science_and_technology
}

enum ColWidth {
  narrow
  medium
  wide
}

enum QuestionType {
  main_idea
  inference
  vocab
}

enum PassageStatus {
  draft
  ready
  flagged
  retired
}

// ─────────────────────────────────────────────
// Table: users
// Core identity record, created on first login.
// clerk_id is used to validate JWTs — the backend never issues tokens.
// ─────────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  clerk_id  String   @unique
  is_admin  Boolean  @default(false) @map("is_admin")
  streak_days Int      @default(0) @map("streak_days")
  last_session_at DateTime? @db.Timestamptz(3) @map("last_session_at")
  created_at DateTime @default(now()) @db.Timestamptz(3) @map("created_at")
  updated_at DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  // Relations
  preferences   UserPreferences?
  sessions      Session[]
  calibrations  Calibration[]
  passageViews  UserPassageSeen[]
  assignments   PassageAssignment[]
  drillViews    UserDrillSeen[]

  @@map("users")
}

// ─────────────────────────────────────────────
// Table: user_prefs
// One row per user. Created with defaults at registration.
// Updated whenever the user changes a setting.
// ─────────────────────────────────────────────
model UserPreferences {
  id             String   @id @default(uuid())
  user_id        String   @unique @map("user_id")
  chunk_size     Int      @default(2)         // 2 or 3 words per highlight chunk
  fading_enabled Boolean  @default(true)      // text fading mode
  guide_enabled  Boolean  @default(true)      // pacing guide line
  col_width      ColWidth @default(medium)    // column width preference
  font_size_px   Int      @default(14)        // 10 | 12 | 14 | 16 px
  domains        Domain[] @default([philosophy, psychology, history, arts_and_museum, society, culture, biology, science_and_technology])
  mcq_timer      Int      @default(0)         // 0 = no time, otherwise 15-180 seconds
  highlight_intensity String @default("intense") // subtle | moderate | intense
  auto_center_scroll Boolean  @default(true)      // auto-center active line
  laap_enabled   Boolean  @default(true)      @map("laap_enabled") // linguistic-aware adaptive pacing
  mcqs_enabled   Boolean  @default(true)      @map("mcqs_enabled") // enable/disable MCQs after reading session
  progress_bar_enabled Boolean  @default(true)      @map("progress_bar_enabled") // show/hide HUD progress bar
  timer_enabled  Boolean  @default(true)      @map("timer_enabled")        // show/hide HUD timer
  roadmaps_enabled Boolean  @default(true)      @map("roadmaps_enabled")     // paragraph roadmaps enabled
  timed_passages_enabled Boolean  @default(true)      @map("timed_passages_enabled")
  gemini_api_key String?  @map("gemini_api_key")

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_prefs")
}

// ─────────────────────────────────────────────
// Table: passages
// Shared content pool — not per-user.
// Generated by the AI background job (passageWarmingJob).
// A passage is available to any user who has not yet seen it.
// ─────────────────────────────────────────────
model Passage {
  id           String  @id @default(uuid())
  body         String  // Full passage text, 250–350 words
  word_count   Int     @map("word_count")
  domain       Domain
  generated_by String  @map("generated_by") // e.g. "claude-sonnet-4-6"
  source       String  @default("seed")
  status       PassageStatus @default(ready)
  quality_score Int?   @map("quality_score")
  title        String  @map("title")
  topic_key    String? @map("topic_key")
  hash         String? @unique
  flagged      Boolean @default(false)       // true = excluded from pool pending review
  flag_count   Int     @default(0) @map("flag_count")
  paragraph_roadmaps String[] @default([]) @map("paragraph_roadmaps")
  date_added   DateTime @default(now()) @db.Timestamptz(3) @map("date_added")
  created_at   DateTime @default(now()) @db.Timestamptz(3) @map("created_at")

  // Relations
  questions    Question[]
  sessions     Session[]
  views        UserPassageSeen[]
  assignments  PassageAssignment[]

  @@map("passages")
}

model PassageAssignment {
  id               String   @id @default(uuid())
  user_id          String   @map("user_id")
  passage_id       String   @map("passage_id")
  domain_requested Domain?  @map("domain_requested")
  assigned_at      DateTime @default(now()) @db.Timestamptz(3) @map("assigned_at")
  left_at_ms       Int?     @map("left_at_ms")

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  passage Passage @relation(fields: [passage_id], references: [id], onDelete: Cascade)

  @@index([user_id, assigned_at])
  @@index([passage_id, assigned_at])
  @@map("passage_assignments")
}

// ─────────────────────────────────────────────
// Table: questions
// Three rows per passage (main_idea, inference, vocab).
// Generated alongside the passage by the AI job.
// correct_index is NEVER sent to the frontend until after submission.
// ─────────────────────────────────────────────
model Question {
  id            String       @id @default(uuid())
  passage_id    String       @map("passage_id")
  type          QuestionType
  stem          String       // The question text
  options       String[]     // 4 answer option strings (A, B, C, D order)
  correct_index Int          @map("correct_index") // 0–3 index into options[]
  explanations  String[]     // 4 explanation strings corresponding to options (A, B, C, D order)

  // Relations
  passage   Passage    @relation(fields: [passage_id], references: [id], onDelete: Cascade)
  responses Response[]

  @@map("questions")
}

// ─────────────────────────────────────────────
// Table: sessions
// One row per *completed* reading session.
// Abandoned / incomplete sessions are never written.
// ─────────────────────────────────────────────
model Session {
  id            String   @id @default(uuid())
  user_id       String   @map("user_id")
  passage_id    String   @map("passage_id")
  target_wpm    Int      @map("target_wpm")    // WPM the user selected before starting
  actual_wpm    Int      @map("actual_wpm")    // Calculated: word_count / (elapsed_ms / 60000)
  elapsed_ms    Int      @map("elapsed_ms")    // Reading phase duration in milliseconds
  comprehension Int                             // 0–3 MCQs answered correctly
  chunk_size    Int      @map("chunk_size")    // Snapshot of pref at session time
  fading_used   Boolean  @map("fading_used")
  guide_used    Boolean  @map("guide_used")
  domain        String                          // Passage domain (denormalised for query perf)
  started_at    DateTime @db.Timestamptz(3) @map("started_at")
  completed_at  DateTime @db.Timestamptz(3) @map("completed_at")

  // Relations
  user      User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  passage   Passage    @relation(fields: [passage_id], references: [id])
  responses Response[]

  @@map("sessions")
}

// ─────────────────────────────────────────────
// Table: responses
// Three rows per completed session (one per MCQ).
// is_correct is computed on insert by comparing selected_index
// to questions.correct_index — never trusted from the client.
// ─────────────────────────────────────────────
model Response {
  id             String  @id @default(uuid())
  session_id     String  @map("session_id")
  question_id    String  @map("question_id")
  selected_index Int     @map("selected_index") // 0–3
  is_correct     Boolean @map("is_correct")      // Server-computed
  time_taken_ms  Int     @map("time_taken_ms")   // Milliseconds from question display to answer

  // Relations
  session  Session  @relation(fields: [session_id], references: [id], onDelete: Cascade)
  question Question @relation(fields: [question_id], references: [id])

  @@map("responses")
}

// ─────────────────────────────────────────────
// Table: calibrations
// One row per calibration event.
// The most recent row per user is their current baseline WPM.
// Historical rows are retained for trend display.
// ─────────────────────────────────────────────
model Calibration {
  id          String   @id @default(uuid())
  user_id     String   @map("user_id")
  wpm         Int                          // Calculated from 100-word calibration passage
  recorded_at DateTime @default(now()) @db.Timestamptz(3) @map("recorded_at")

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("calibrations")
}

// ─────────────────────────────────────────────
// Table: user_passage_seen
// Join table. Inserted when a passage is assigned to a user's session.
// Ensures no passage repeats for the same user.
// ─────────────────────────────────────────────
model UserPassageSeen {
  id         String   @id @default(uuid())
  user_id    String   @map("user_id")
  passage_id String   @map("passage_id")
  seen_at    DateTime @default(now()) @db.Timestamptz(3) @map("seen_at")
  reallowed  Boolean  @default(false) @map("reallowed")
  time_spent_ms Int     @default(0) @map("time_spent_ms")

  // Relations
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  passage Passage @relation(fields: [passage_id], references: [id], onDelete: Cascade)

  // A user can only see a given passage once
  @@unique([user_id, passage_id])
  @@map("user_passage_seen")
}

model DrillPassage {
  id            String   @id @default(uuid())
  level         Int      // 1 to 6
  body          String   // Passage body (65-85 words)
  word_count    Int      @map("word_count")
  question_stem String   @map("question_stem")
  options       String[] // 2 option strings
  correct_index Int      @map("correct_index") // 0 or 1
  source        String   @default("seed")
  created_at    DateTime @default(now()) @db.Timestamptz(3) @map("created_at")

  // Relations
  views         UserDrillSeen[]

  @@map("drill_passages")
}

model UserDrillSeen {
  id               String   @id @default(uuid())
  user_id          String   @map("user_id")
  drill_passage_id String   @map("drill_passage_id")
  seen_at          DateTime @default(now()) @db.Timestamptz(3) @map("seen_at")

  // Relations
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  drillPassage DrillPassage @relation(fields: [drill_passage_id], references: [id], onDelete: Cascade)

  // A user can only see a given drill passage once
  @@unique([user_id, drill_passage_id])
  @@map("user_drill_seen")
}
